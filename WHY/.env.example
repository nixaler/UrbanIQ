# ── DATABASE ────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/why_dating

# ── AUTH ────────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-something-long-and-random-in-production

# ── SERVER ──────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── TWILIO (SMS verification) ────────────────────────────────────────────────────
# Leave blank to use SMS stub (logs code to console)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── OPENAI (AI content moderation) ──────────────────────────────────────────────
# Leave blank to auto-pass all moderation (dev only)
OPENAI_API_KEY=

# ── APPLE PUSH NOTIFICATIONS (APNs) ─────────────────────────────────────────────
# Leave blank to use push stub (logs to console)
APN_KEY=          # Path to .p8 key file or raw key content
APN_KEY_ID=       # 10-char key ID from Apple Developer portal
APN_TEAM_ID=      # 10-char Team ID from Apple Developer portal
APN_BUNDLE_ID=com.why.datingapp
